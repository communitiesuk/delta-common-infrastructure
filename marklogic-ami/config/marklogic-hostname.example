# Config for setup-marklogic-hostname.service
# This hostname will be set before MarkLogic starts; use the same value for MARKLOGIC_HOST.

# Required: hostname (short or FQDN) to set and register to this instance's private IP
MARKLOGIC_HOSTNAME=ml-node01.example.local

# Optional: register the hostname in Route53 (private hosted zone)
# R53_HOSTED_ZONE_ID=Z0123456789ABCDEF
# R53_DOMAIN=ml-node01.example.local
